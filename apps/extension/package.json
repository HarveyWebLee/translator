{
  "name": "@translator/extension",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "AI 网页翻译扩展：React 19 + Antd 6 + Vite + @crxjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@ant-design/icons": "^6.0.0",
    "@tanstack/react-query": "^5.59.16",
    "@translator/llm-core": "workspace:*",
    "@translator/shared-types": "workspace:*",
    "antd": "^6.4.3",
    "dayjs": "^1.11.13",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "2.0.0-beta.30",
    "@translator/eslint-config": "workspace:*",
    "@translator/tsconfig": "workspace:*",
    "@types/chrome": "^0.0.278",
    "@types/node": "^20.16.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "eslint": "^8.57.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
