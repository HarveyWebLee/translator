# ----------------- 基础 -----------------
NODE_ENV=development
PORT=19696
CORS_ORIGINS=chrome-extension://*,http://localhost:9696

# ----------------- 数据库 -----------------
# 本地可用 docker-compose 启动：docker compose up -d
DATABASE_URL=postgresql://translator:translator@localhost:15439/translator?schema=public

# ----------------- JWT -----------------
JWT_SECRET=please-change-me-in-production-min-32-chars
JWT_ACCESS_TTL_SEC=3600
JWT_REFRESH_TTL_SEC=2592000

# ----------------- 系统持有的 LLM API Keys（仅 premium 会员使用） -----------------
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ----------------- 免费翻译引擎 -----------------
# LibreTranslate 公共实例或自建实例
LIBRE_TRANSLATE_BASE_URL=https://libretranslate.com
LIBRE_TRANSLATE_API_KEY=

# ----------------- OAuth（骨架，本期 TODO） -----------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
OAUTH_CALLBACK_BASE_URL=http://localhost:19696

# ----------------- 短信（骨架，本期 TODO） -----------------
SMS_PROVIDER=mock
SMS_API_KEY=
SMS_SIGN_NAME=
