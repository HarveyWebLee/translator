{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": ".cursor/hooks/format-after-edit.sh",
        "matcher": "Write|TabWrite",
        "failClosed": false
      }
    ],
    "beforeShellExecution": [
      {
        "command": ".cursor/hooks/guard-shell.sh",
        "matcher": "rm\\s+-rf|--force|publish|DROP\\s+TABLE|TRUNCATE\\s+TABLE",
        "failClosed": false
      }
    ]
  }
}
