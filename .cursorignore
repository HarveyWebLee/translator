# Cursor 索引忽略清单：减少噪声、保护敏感文件。
# 语法同 .gitignore。

# ============ 依赖 ============
node_modules/
**/node_modules/
.pnpm-store/

# ============ 构建产物 ============
dist/
build/
.turbo/
.nest/
coverage/
*.tsbuildinfo
apps/extension/dist/
apps/extension/release/
apps/server/dist/

# ============ 锁文件 ============
pnpm-lock.yaml
package-lock.json
yarn.lock

# ============ Prisma 生成物 ============
apps/server/prisma/migrations/
apps/server/node_modules/.prisma/

# ============ 敏感配置（禁止索引到密钥） ============
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example
config.local.json
**/config.local.json
*.pem
*.key
*.crt

# ============ 编辑器与系统 ============
.vscode/
.idea/
.DS_Store
Thumbs.db
*.log
logs/

# ============ 二进制与媒体 ============
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.ico
*.pdf
*.zip
*.tar.gz
*.mp4
!apps/extension/public/icons/*.png

# ============ 历史备份 ============
*.bak
*.orig
