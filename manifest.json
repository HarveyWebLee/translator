{
  "manifest_version": 3,
  "name": "英文网页翻译助手",
  "version": "1.1.2",
  "description": "识别当前标签页是否为英文网站，由用户选择是否通过 DeepSeek 大模型翻译为简体中文。",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "英文网页翻译助手"
  },
  "options_page": "src/options/options.html",
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://api.deepseek.com/*", "<all_urls>"],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/content/content.js", "src/content/selection-translate.js"],
      "css": ["src/content/content.css", "src/content/selection-panel.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
